# HealthOps AI Platform — Environment Configuration
# Copy this file to .env and update values as needed
# IMPORTANT: Never commit .env to version control

# AWS Configuration (uses IAM roles in production — no keys needed)
AWS_REGION=us-east-1

# Bedrock Model (no API key required — uses IAM role)
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# SageMaker Endpoint Name
SAGEMAKER_ENDPOINT=healthops-anomaly-endpoint

# OPA Policy Engine URL
OPA_URL=http://opa:8181

# S3 Data Bucket
DATA_BUCKET=healthops-data

# Application Settings
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# Alerting (optional — for production)
ALERT_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:healthops-alerts
